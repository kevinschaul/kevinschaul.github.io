---
import { getCollection } from "astro:content"
import SiteLayout from "@/layouts/SiteLayout.astro"
import Pagination from "@/components/Pagination.astro"
import ProjectItem from "@/components/ProjectItem.astro"
import { paginatedPaths, sortByDateDesc } from "@/lib/collections"

export async function getStaticPaths() {
  return paginatedPaths(sortByDateDesc(await getCollection("project")))
}

const { items, page, totalPages } = Astro.props
---

<SiteLayout title={`Projects, page ${page}`} canonical={`/project/page/${page}/`} rssHref="/project/index.xml">
  <h2 class="t-kicker">Projects</h2>
  <div class="t-grid">
    {items.map((entry) => <ProjectItem entry={entry} />)}
  </div>
  <Pagination page={page} totalPages={totalPages} basePath="/project/" />
</SiteLayout>
