---
import { getCollection } from "astro:content"
import SiteLayout from "../../layouts/SiteLayout.astro"
import Pagination from "../../components/Pagination.astro"
import ProjectItem from "../../components/ProjectItem.astro"
import { notDraft, paginate, sortByDateDesc } from "../../lib/collections"

const entries = sortByDateDesc((await getCollection("project")).filter(notDraft))
const pages = paginate(entries)
---

<SiteLayout title="Projects" canonical="/project/" rssHref="/project/index.xml">
  <h2 class="t-kicker">Projects</h2>
  <div class="t-grid">
    {pages[0].map((entry) => <ProjectItem entry={entry} />)}
  </div>
  <Pagination page={1} totalPages={pages.length} basePath="/project/" />
</SiteLayout>
