---
import { getCollection, render } from "astro:content"
import SiteLayout from "@/layouts/SiteLayout.astro"
import { sectionParams, entryPath, tagUrl } from "@/lib/site"
import { formatDateMedium } from "@/lib/urls"
import { countWords, publishedISO, summarize } from "@/lib/text"

export async function getStaticPaths() {
  const entries = await getCollection("project")
  return entries.map((entry) => ({
    params: sectionParams(entry),
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const body = entry.body ?? ""
const description = entry.data.blurb ?? summarize(body)
const published = publishedISO(entry.data.date)
---

<SiteLayout
  title={entry.data.title}
  description={description}
  canonical={entryPath(entry)}
  externalUrl={entry.data.external_url}
  isPage
  article={{
    section: entry.collection,
    published,
    modified: published,
    wordCount: countWords(body),
    keywords: (entry.data.tags ?? []).filter(Boolean),
  }}
>
  <article>
    <header>
      <h1>{entry.data.title}</h1>
      <div class="t-meta">
        <time datetime={published}>{formatDateMedium(entry.data.date)}</time>
      </div>
    </header>
    <Content />
    {
      entry.data.tags?.length > 0 && (
        <footer class="t-tags">
          {entry.data.tags.filter(Boolean).map((tag) => (
            <a class="t-tag" href={tagUrl(tag)}>
              {tag}
            </a>
          ))}
        </footer>
      )
    }
  </article>
</SiteLayout>
