---
import { getCollection } from "astro:content"
import SiteLayout from "@/layouts/SiteLayout.astro"
import Pagination from "@/components/Pagination.astro"
import PostList from "@/components/PostList.astro"
import { paginatedPaths, sortByDateDesc } from "@/lib/collections"

export async function getStaticPaths() {
  return paginatedPaths(sortByDateDesc(await getCollection("post")))
}

const { items, page, totalPages } = Astro.props
---

<SiteLayout title={`Long posts, page ${page}`} canonical={`/post/page/${page}/`} rssHref="/post/index.xml">
  <h2 class="t-kicker">Long posts</h2>
  <PostList entries={items} />
  <Pagination page={page} totalPages={totalPages} basePath="/post/" />
</SiteLayout>
