---
import { getCollection } from "astro:content"
import SiteLayout from "@/layouts/SiteLayout.astro"
import LinkItem from "@/components/LinkItem.astro"
import Pagination from "@/components/Pagination.astro"
import { paginatedPaths, sortByDateDesc } from "@/lib/collections"

export async function getStaticPaths() {
  return paginatedPaths(sortByDateDesc(await getCollection("link")))
}

const { items, page, totalPages } = Astro.props
---

<SiteLayout title={`Short posts, page ${page}`} canonical={`/link/page/${page}/`} rssHref="/link/index.xml">
  <h2 class="t-kicker">Short posts</h2>
  <div class="t-stream">
    {items.map((entry) => <LinkItem entry={entry} />)}
  </div>
  <Pagination page={page} totalPages={totalPages} basePath="/link/" />
</SiteLayout>
