---
import { getCollection } from "astro:content"
import SiteLayout from "@/layouts/SiteLayout.astro"
import Pagination from "@/components/Pagination.astro"
import PostList from "@/components/PostList.astro"
import { paginatedPaths, sortByDateDesc } from "@/lib/collections"

export async function getStaticPaths() {
  return paginatedPaths(sortByDateDesc(await getCollection("til")))
}

const { items, page, totalPages } = Astro.props
---

<SiteLayout title={`TIL, page ${page}`} canonical={`/til/page/${page}/`} rssHref="/til/index.xml">
  <h2 class="t-kicker">TIL</h2>
  <PostList entries={items} />
  <Pagination page={page} totalPages={totalPages} basePath="/til/" />
</SiteLayout>
